<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_outline"
    android:padding="16dp">

    <!-- Accent bar kiri — signature element desain ini -->
    <View
        android:id="@+id/statusBar"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@drawable/bar_status_pending"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Konten tugas -->
    <LinearLayout
        android:id="@+id/contentBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toEndOf="@id/statusBar"
        app:layout_constraintEnd_toStartOf="@id/badgeStatus"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvJudulTugas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Judul tugas di sini"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_person"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvAssignedTo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Belum diassign"
                style="@style/Text.Caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_calendar"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="—"
                style="@style/Text.Caption" />
        </LinearLayout>

    </LinearLayout>

    <!-- Badge status kanan atas -->
    <TextView
        android:id="@+id/badgeStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill_soft"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Belum"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Grup nama kecil di bawah kanan -->
    <TextView
        android:id="@+id/tvGrupNama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Grup —"
        android:textColor="@color/text_disabled"
        android:textSize="10sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/badgeStatus" />

</androidx.constraintlayout.widget.ConstraintLayout>
