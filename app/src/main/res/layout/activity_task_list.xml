<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header dengan back button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Kembali"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/titleBlock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvNamaGrup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Grup"
                    style="@style/Text.Display" />

                <TextView
                    android:id="@+id/tvInfoGrup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 tugas · 0% selesai"
                    style="@style/Text.Caption" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Filter chips: Semua / Belum / Proses / Selesai -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/filterChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="Semua"
                    android:background="@drawable/bg_button_primary"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_on_accent"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipBelum"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="Belum"
                    android:background="@drawable/bg_button_ghost"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipProses"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="Proses"
                    android:background="@drawable/bg_button_ghost"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipSelesai"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="Selesai"
                    android:background="@drawable/bg_button_ghost"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTugas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="24dp"
            android:paddingBottom="88dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/emptyStateTugas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada tugas"
                style="@style/Text.Title"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ketuk + untuk menambah tugas pertama"
                style="@style/Text.Caption" />
        </LinearLayout>

    </LinearLayout>

    <!-- FAB tambah tugas -->
    <FrameLayout
        android:id="@+id/fabTambahTugas"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:background="@drawable/bg_fab"
        android:elevation="6dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_plus"
            android:contentDescription="Tambah tugas baru" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
