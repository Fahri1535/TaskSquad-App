<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Kembali"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Buat akun baru"
            style="@style/Text.Display"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Isi data berikut untuk mulai menggunakan aplikasi"
            style="@style/Text.Body"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nama lengkap -->
        <TextView
            android:id="@+id/labelNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Nama lengkap"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelNama"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etNama"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:hint="Contoh: Mohamad Fahri Akbar"
                android:inputType="textPersonName|textCapWords"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_person"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Email -->
        <TextView
            android:id="@+id/labelEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Email"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapNama"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etEmail"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:hint="nama@email.com"
                android:inputType="textEmailAddress"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_mail"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Password -->
        <TextView
            android:id="@+id/labelPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Kata sandi"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapEmail"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etPassword"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:hint="Minimal 6 karakter"
                android:inputType="textPassword"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye_off"
                android:contentDescription="Tampilkan kata sandi" />
        </FrameLayout>

        <!-- Konfirmasi Password -->
        <TextView
            android:id="@+id/labelKonfirmasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Konfirmasi kata sandi"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapPassword"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapKonfirmasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelKonfirmasi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etKonfirmasi"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:hint="Ulangi kata sandi"
                android:inputType="textPassword"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/btnToggleKonfirmasi"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye_off"
                android:contentDescription="Tampilkan konfirmasi kata sandi" />
        </FrameLayout>

        <Button
            android:id="@+id/btnRegister"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Buat akun"
            app:layout_constraintTop_toBottomOf="@id/wrapKonfirmasi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnRegister"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Text.Body"
                android:textColor="@color/text_secondary"
                android:text="Sudah punya akun? " />

            <TextView
                android:id="@+id/tvGoToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Text.Body"
                android:textColor="@color/accent_start"
                android:fontFamily="sans-serif-medium"
                android:text="Masuk" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
