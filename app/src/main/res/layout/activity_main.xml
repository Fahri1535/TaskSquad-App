<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation custom -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tab Dashboard -->
        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconDashboard"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home_active"
                android:contentDescription="Dashboard" />

            <TextView
                android:id="@+id/navLabelDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Beranda"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/accent_start" />
        </LinearLayout>

        <!-- Tab Grup -->
        <LinearLayout
            android:id="@+id/navGrup"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconGrup"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_layers"
                android:contentDescription="Grup Tugas" />

            <TextView
                android:id="@+id/navLabelGrup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Grup"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Tab Profil -->
        <LinearLayout
            android:id="@+id/navProfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconProfil"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_user_circle"
                android:contentDescription="Profil" />

            <TextView
                android:id="@+id/navLabelProfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Profil"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
