<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="28dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/stroke_subtle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Grup baru"
        style="@style/Text.Title"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama grup"
        style="@style/Text.Label"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etNamaGrup"
        style="@style/InputField"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Contoh: Kelompok 7 RPL"
        android:inputType="textCapSentences"
        android:singleLine="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Warna identitas"
        style="@style/Text.Label"
        android:layout_marginBottom="12dp" />

    <!-- Color picker row (klik salah satu untuk memilih warna identitas grup) -->
    <LinearLayout
        android:id="@+id/colorPickerRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/swatchGreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:layout_marginEnd="10dp">
            <View android:id="@+id/colorGreen"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/swatch_green" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/swatchAmber"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:layout_marginEnd="10dp">
            <View android:id="@+id/colorAmber"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/swatch_amber" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/swatchRed"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:layout_marginEnd="10dp">
            <View android:id="@+id/colorRed"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/swatch_red" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/swatchGray"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp">
            <View android:id="@+id/colorGray"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/swatch_gray" />
        </FrameLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnBuatGrup"
        style="@style/Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:text="Buat grup" />

</LinearLayout>
