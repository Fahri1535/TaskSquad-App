<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Kembali"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Tugas baru"
            style="@style/Text.Display"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Judul tugas -->
        <TextView
            android:id="@+id/labelJudul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Judul tugas"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etJudul"
            style="@style/InputField"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:hint="Contoh: Buat laporan bab 3"
            android:inputType="textCapSentences"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/labelJudul"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/labelDeskripsi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Deskripsi (opsional)"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/etJudul"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etDeskripsi"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:hint="Catatan tambahan tentang tugas ini..."
            android:inputType="textCapSentences|textMultiLine"
            android:gravity="top"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/labelDeskripsi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Assign ke -->
        <TextView
            android:id="@+id/labelAssign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ditugaskan kepada"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/etDeskripsi"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapAssign"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelAssign"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Spinner
                android:id="@+id/spinnerAssignTo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:spinnerMode="dropdown" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_person"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Deadline -->
        <TextView
            android:id="@+id/labelDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Deadline"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapAssign"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapDeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelDeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvDeadline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:gravity="start|center_vertical"
                android:text="Pilih tanggal"
                android:textColor="@color/text_disabled"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_calendar"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Status tugas -->
        <TextView
            android:id="@+id/labelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Status"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapDeadline"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/statusGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btnStatusBelum"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Belum"
                android:background="@drawable/bg_button_primary"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnStatusProses"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Proses"
                android:background="@drawable/bg_button_ghost"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnStatusSelesai"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Selesai"
                android:background="@drawable/bg_button_ghost"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Tombol simpan -->
        <Button
            android:id="@+id/btnSimpan"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Simpan tugas"
            app:layout_constraintTop_toBottomOf="@id/statusGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnBatal"
            style="@style/Button.Ghost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Batal"
            app:layout_constraintTop_toBottomOf="@id/btnSimpan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
