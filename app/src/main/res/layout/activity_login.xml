<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp">

        <!-- Brand mark: accent gradient block, bukan icon AI generic -->
        <View
            android:id="@+id/brandMark"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="64dp"
            android:background="@drawable/bg_fab"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/brandInitial"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="T"
            android:textColor="@color/text_on_accent"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/brandMark"
            app:layout_constraintBottom_toBottomOf="@id/brandMark"
            app:layout_constraintStart_toStartOf="@id/brandMark"
            app:layout_constraintEnd_toEndOf="@id/brandMark" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Selamat datang kembali"
            style="@style/Text.Display"
            app:layout_constraintTop_toBottomOf="@id/brandMark"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Masuk untuk melanjutkan mengelola tugas kelompokmu"
            style="@style/Text.Body"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email field -->
        <TextView
            android:id="@+id/labelEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Email"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etEmail"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:hint="nama@email.com"
                android:inputType="textEmailAddress"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_mail"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Password field -->
        <TextView
            android:id="@+id/labelPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Kata sandi"
            style="@style/Text.Label"
            app:layout_constraintTop_toBottomOf="@id/wrapEmail"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/wrapPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etPassword"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:hint="Minimal 6 karakter"
                android:inputType="textPassword"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye_off"
                android:contentDescription="Tampilkan kata sandi" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Lupa kata sandi?"
            android:textColor="@color/accent_start"
            android:fontFamily="sans-serif-medium"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/wrapPassword"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnLogin"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Masuk"
            app:layout_constraintTop_toBottomOf="@id/tvForgotPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/dividerLeft"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="12dp"
            android:background="@color/stroke_subtle"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvOr"
            app:layout_constraintBottom_toBottomOf="@id/tvOr" />

        <TextView
            android:id="@+id/tvOr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="atau"
            style="@style/Text.Caption"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toEndOf="@id/dividerLeft"
            app:layout_constraintEnd_toStartOf="@id/dividerRight" />

        <View
            android:id="@+id/dividerRight"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="12dp"
            android:background="@color/stroke_subtle"
            app:layout_constraintTop_toTopOf="@id/tvOr"
            app:layout_constraintBottom_toBottomOf="@id/tvOr"
            app:layout_constraintStart_toEndOf="@id/tvOr"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvOr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Text.Body"
                android:textColor="@color/text_secondary"
                android:text="Belum punya akun? " />

            <TextView
                android:id="@+id/tvGoToRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Text.Body"
                android:textColor="@color/accent_start"
                android:fontFamily="sans-serif-medium"
                android:text="Daftar" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
