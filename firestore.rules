rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // users/{uid}
    // Dipakai untuk lookup "tambah anggota lewat email"
    // (GroupRepository.addMemberByEmail query whereEqualTo("email", ...)).
    // Semua user login boleh baca (perlu query lintas user untuk cari email),
    // tapi hanya pemilik uid yang boleh menulis dokumennya sendiri.
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // groups/{groupId}
    // Read: boleh dibaca oleh siapa saja yang login. Ini perlu supaya
    //   query cari grup by joinCode (proses "join grup") bisa jalan --
    //   user BELUM jadi member saat query itu dijalankan, jadi read tidak
    //   bisa disyaratkan "sudah jadi member duluan". joinCode sendiri
    //   berfungsi sebagai kunci akses: hanya yang tahu kodenya yang bisa
    //   menemukan grup lewat whereEqualTo("joinCode", ...).
    // Create: hanya boleh membuat grup dengan dirinya sendiri sebagai
    //   ownerId dan sudah ada di memberIds saat pertama kali dibuat.
    // Update: dua kasus sah diizinkan tanpa perlu sudah jadi member dulu:
    //   1) join by code -> menambahkan diri sendiri ke memberIds
    //   2) add member by email -> member existing menambahkan uid lain
    //   Selain itu, hanya member yang boleh update field lain.
    // Delete: hanya owner.
    // ---------------------------------------------------------
    match /groups/{groupId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
                        request.resource.data.ownerId == request.auth.uid &&
                        request.auth.uid in request.resource.data.memberIds;

      allow update: if request.auth != null && (
                        // sudah jadi member -> boleh update apa saja (termasuk tambah member lain)
                        request.auth.uid in resource.data.memberIds ||
                        // belum member, tapi update ini cuma menambahkan dirinya sendiri
                        // ke memberIds (join by code) dan tidak mengubah field lain
                        (
                          request.auth.uid in request.resource.data.memberIds &&
                          request.resource.data.ownerId == resource.data.ownerId &&
                          request.resource.data.namaGrup == resource.data.namaGrup &&
                          request.resource.data.joinCode == resource.data.joinCode
                        )
                      );

      allow delete: if request.auth != null &&
                        request.auth.uid == resource.data.ownerId;
    }

    // ---------------------------------------------------------
    // tasks/{taskId}
    // Akses task ditentukan oleh keanggotaan grup terkait (groupId),
    // bukan oleh userId (pembuat task). Semua member grup boleh
    // baca/ubah/hapus task di grup tersebut.
    // Create: groupId di task baru wajib grup yang uid-nya sudah jadi member.
    // ---------------------------------------------------------
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null &&
                        request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;

      allow create: if request.auth != null &&
                        request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds;
    }
  }
}
